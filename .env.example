# Gravitre Operator AI — Environment template
# Copy to .env and fill in values. NEVER commit .env.

# Supabase (required)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT Secret (Project Settings → API → JWT Secret) — for server-side token validation
SUPABASE_JWT_SECRET=your-jwt-secret
# Optional: JWT issuer (default derived from SUPABASE_URL + /auth/v1)
# SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
# Optional: JWT audience (default "authenticated")
# SUPABASE_JWT_AUDIENCE=authenticated
# Optional: clock skew leeway in seconds (default 60)
# SUPABASE_JWT_LEEWAY_SECONDS=60

# App environment (dev|staging|production)
APP_ENV=dev

# OpenAI (Phase 1 — BE-10 RAG embeddings)
# OPENAI_API_KEY=sk-... (required in staging/production)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSION=1536

# Stripe Billing (MVP)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_STARTER=price_...
# STRIPE_PRICE_ID_GROWTH=price_...
# STRIPE_PRICE_ID_SCALE=price_...
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# IN-00: Fernet key for connector secrets (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# CONNECTOR_SECRETS_ENCRYPTION_KEY=... (required in staging/production)

# Phase 6: Kill switches (default false)
# DISABLE_EXECUTE=false
# DISABLE_CONNECTORS=false
# DISABLE_INGESTION=false

# Phase 6: Metrics rollup toggle (default false)
# METRICS_ROLLUP_ENABLED=false

# Backend base URL (server-only; used by Next.js API route to proxy to FastAPI)
FASTAPI_BASE_URL=http://localhost:8000

# Frontend (apps/web) — NEXT_PUBLIC_* only (browser never sees backend URL)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
